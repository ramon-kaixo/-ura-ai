{
  "log_dir": "/opt/ura/logs/maintenance",
  "exclude_patterns": [
    "*.db",
    "*.sqlite",
    "*.sqlite-wal",
    "*.key",
    "*.pem",
    "*.crt",
    "*.env",
    "*.secret",
    "/home/*/URA/",
    "/home/*/projects/",
    "/home/*/Documents/",
    "/home/*/Desktop/",
    "/home/*/Downloads/",
    "/opt/ura/",
    "/etc/",
    "/var/lib/"
  ],
  "thresholds": {
    "docker_images": 10,
    "docker_volumes": 5,
    "cache_size": 2,
    "log_size": 1
  },
  "retention_days": {
    "logs": 7,
    "cache": 30,
    "docker_build": 7
  },
  "allowed_temp_dirs": [
    "/tmp",
    "/var/tmp"
  ],
  "allowed_log_dirs": [
    "/var/log",
    "/opt/ura/logs"
  ]
}
