#!/usr/bin/env python3
"""ura-audit — 10 herramientas deterministas."""

import json
import subprocess
import sys
import time
from datetime import datetime
from pathlib import Path

RAIZ = Path(__file__).resolve().parent
REPORTE = Path(f"/tmp/ura-audit-{datetime.now().strftime('%Y%m%d_%H%M%S')}.json")
QUICK = "--quick" in sys.argv
r = {"ts": datetime.now().isoformat(), "tools": {}, "critico": False}


def run(n, cmd, crit=False, to=120):
    t0 = time.time()
    ok = True
    try:
        p = subprocess.run(cmd, capture_output=True, text=True, timeout=to, cwd=RAIZ, check=False)
        ok = p.returncode == 0
    except:
        ok = False
    r["tools"][n] = {"ok": ok, "ms": round((time.time() - t0) * 1000), "crit": crit}
    if not ok and crit:
        r["critico"] = True
    return ok


print("\n  ura-audit (10 herramientas)\n")

# 1. Ruff
run("ruff", ["python3", "-m", "ruff", "check", ".", "--select", "ALL"])
print(f"  [1] ruff:      {'OK' if r['tools']['ruff']['ok'] else 'FALLOS'} ({r['tools']['ruff']['ms']}ms)")

if not QUICK:
    # 2. Radon
    run("radon", ["python3", "-m", "radon", "cc", ".", "-s", "-a"], to=60)
    print(f"  [2] radon:     {'OK' if r['tools']['radon']['ok'] else 'FALLOS'} ({r['tools']['radon']['ms']}ms)")

    # 3. Mypy
    run(
        "mypy", ["python3", "-m", "mypy", "--strict", "mochila_engine.py", "prompt_injector.py", "core/", "cli/"], to=60
    )
    print(f"  [3] mypy:      {'OK' if r['tools']['mypy']['ok'] else 'FALLOS'} ({r['tools']['mypy']['ms']}ms)")

# 4. Bandit
run("bandit", ["python3", "-m", "bandit", "-r", "core/", "cli/"], crit=True)
print(f"  [4] bandit:    {'OK' if r['tools']['bandit']['ok'] else 'ALERTA'} ({r['tools']['bandit']['ms']}ms)")

# 5. Safety
run("safety", ["python3", "-m", "safety", "check"], crit=True)
print(f"  [5] safety:    {'OK' if r['tools']['safety']['ok'] else 'ALERTA'} ({r['tools']['safety']['ms']}ms)")

# 6. Vulture
run("vulture", ["python3", "-m", "vulture", ".", "--min-confidence", "80"])
print(f"  [6] vulture:   {'OK' if r['tools']['vulture']['ok'] else 'FALLOS'} ({r['tools']['vulture']['ms']}ms)")

if not QUICK:
    # 7. jscpd (if available)
    run("jscpd", ["npx", "jscpd", ".", "--threshold", "5", "--pattern", "*.py"], to=30)
    print(f"  [7] jscpd:     {'OK' if r['tools']['jscpd']['ok'] else 'FALLOS'} ({r['tools']['jscpd']['ms']}ms)")

# 8. Tests
run(
    "tests",
    [
        "python3",
        "-m",
        "pytest",
        "-q",
        "--tb=short",
        "test_mochila.py",
        "test_ast_sentinel.py",
        "test_prompt_injector.py",
        "test_memoria_fallos.py",
        "test_memoria_movimiento.py",
        "-p",
        "no:testpaths",
    ],
    crit=True,
)
print(f"  [8] tests:     {'OK' if r['tools']['tests']['ok'] else 'ALERTA'} ({r['tools']['tests']['ms']}ms)")

# 9. Coverage
run(
    "coverage",
    [
        "python3",
        "-m",
        "pytest",
        "test_mochila.py",
        "test_ast_sentinel.py",
        "test_prompt_injector.py",
        "test_memoria_fallos.py",
        "test_memoria_movimiento.py",
        "--cov=mochila_engine",
        "--cov=prompt_injector",
        "--cov=core.guardians.ast_sentinel",
        "--cov=memoria_fallos",
        "--cov=memoria_movimiento",
        "--cov-report=term-missing",
        "-p",
        "no:testpaths",
    ],
    to=30,
)
print(f"  [9] coverage:  {'OK' if r['tools']['coverage']['ok'] else 'FALLOS'} ({r['tools']['coverage']['ms']}ms)")

# 10. mutmut (solo mochila_engine)
run("mutmut", ["python3", "-m", "mutmut", "run", "--paths-to-mutate=mochila_engine.py"], to=120)
print(f" [10] mutmut:    {'OK' if r['tools']['mutmut']['ok'] else 'FALLOS'} ({r['tools']['mutmut']['ms']}ms)")

p = sum(1 for v in r["tools"].values() if v["ok"])
f = len(r["tools"]) - p
REPORTE.write_text(json.dumps(r, indent=2, ensure_ascii=False))
print(f"\n  Reporte: {REPORTE}")
print(f"  {p}/{len(r['tools'])} OK  {'⚠️ Critico' if r['critico'] else '✅ Sin criticos'}")
sys.exit(1 if r["critico"] else 0)
