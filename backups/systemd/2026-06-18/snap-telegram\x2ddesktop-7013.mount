[Unit]
Description=Mount unit for telegram-desktop, revision 7013
After=snapd.mounts-pre.target
Before=snapd.mounts.target

[Mount]
What=/var/lib/snapd/snaps/telegram-desktop_7013.snap
Where=/snap/telegram-desktop/7013
Type=squashfs
Options=nodev,ro,x-gdu.hide,x-gvfs-hide
LazyUnmount=yes

[Install]
WantedBy=snapd.mounts.target
WantedBy=multi-user.target
