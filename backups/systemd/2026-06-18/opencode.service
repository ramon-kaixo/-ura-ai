[Unit]
Description=URA OpenCode AI Assistant
After=network.target ollama.service model-router.service
Wants=network.target

[Service]
Type=simple
User=ramon
ExecStart=/home/ramon/.opencode/bin/opencode web --port 8081 --hostname 0.0.0.0
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
MemoryHigh=4G
MemoryMax=8G

[Install]
WantedBy=multi-user.target
