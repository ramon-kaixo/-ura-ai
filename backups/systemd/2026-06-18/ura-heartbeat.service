[Unit]
Description=URA Mochila Heartbeat — reinicio automatico si /health falla

[Service]
Type=simple
User=ramon
WorkingDirectory=/home/ramon/URA/ura_ia_1972
ExecStart=/usr/bin/python3 core/infra/heartbeat.py --daemon
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
Environment=PYTHONPATH=/home/ramon/URA/ura_ia_1972

[Install]
WantedBy=multi-user.target
