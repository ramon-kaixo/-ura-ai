[Unit]
Description=URA Mochila Middleware — Routing multi-provider + tool injection
After=network.target ollama.service
Wants=network.target ollama.service

[Service]
Type=simple
User=ramon
WorkingDirectory=/home/ramon/URA/ura_ia_1972
ExecStart=/usr/bin/python3 -m uvicorn core.mochila.mochila_server:app --host 127.0.0.1 --port 4098
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
Environment=PYTHONPATH=/home/ramon/URA/ura_ia_1972

[Install]
WantedBy=multi-user.target
