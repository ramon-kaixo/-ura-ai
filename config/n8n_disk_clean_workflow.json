{
  "name": "URA - Disk Clean (reactive)",
  "nodes": [{
    "parameters": {"httpMethod":"POST","path":"disk_clean_trigger","responseMode":"lastNode"},
    "name": "Webhook", "type": "n8n-nodes-base.webhook", "position":[250,300],
    "webhookId":"ura-disk-clean-trigger"
  },{
    "parameters":{"method":"POST","url":"http://localhost:8103/ejecutar","options":{},"sendBody":true,"bodyParameters":{"parameters":[{"name":"estado","value":"={{ $json.estado }}"}]}},
    "name": "Ejecutar limpieza", "type": "n8n-nodes-base.httpRequest", "position":[450,300]
  },{
    "parameters":{"combine":"any","conditions":{"string":[{"value1":"{{ $json.estado }}","operation":"equals","value2":"error"}]}},
    "name": "If error", "type": "n8n-nodes-base.if", "position":[650,300]
  },{
    "parameters":{"fileName":"=/logs/n8n/alertas.jsonl","dataPropertyName":"data","data":"={{ JSON.stringify($json) }}"},
    "name": "Log Alert", "type": "n8n-nodes-base.writeFile", "position":[850,200]
  }],
  "connections":{
    "Webhook":{"main":[[{"node":"Ejecutar limpieza","type":"main","index":0}]]},
    "Ejecutar limpieza":{"main":[[{"node":"If error","type":"main","index":0}]]},
    "If error":{"main":[[{"node":"Log Alert","type":"main","index":0}],[]]},
    "Log Alert":{"main":[[]]}
  }
}
