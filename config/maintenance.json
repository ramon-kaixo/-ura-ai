{
  "log_dir": "/opt/ura/logs/maintenance",
  "exclude_patterns": [
    "*.db",
    "*.sqlite",
    "*.sqlite-wal",
    "*.key",
    "*.pem",
    "*.crt",
    "*.env",
    "*.secret",
    "*.p12",
    "*.pfx",
    "*.jks",
    "*.keystore",
    "/home/*/URA/",
    "/home/*/projects/",
    "/home/*/Documents/",
    "/home/*/Desktop/",
    "/home/*/Downloads/",
    "/home/*/Pictures/",
    "/home/*/Music/",
    "/home/*/Videos/",
    "/home/*.ssh/",
    "/home/*.gnupg/",
    "/opt/ura/",
    "/etc/",
    "/var/lib/",
    "/usr/local/",
    "/home/*/.config/",
    "/home/*/.local/share/"
  ],
  "thresholds": {
    "docker_images": 5,
    "docker_volumes": 3,
    "cache_size": 1,
    "log_size": 0.5
  },
  "retention_days": {
    "logs": 3,
    "cache": 14,
    "docker_build": 3
  },
  "allowed_temp_dirs": [
    "/tmp",
    "/var/tmp"
  ],
  "allowed_log_dirs": [
    "/var/log",
    "/opt/ura/logs"
  ]
}
