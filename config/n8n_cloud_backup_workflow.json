{
  "name": "URA - Cloud Backup",
  "nodes": [{
    "parameters": {"rule":{"interval":[24,"hours"]}},
    "name": "Schedule", "type": "n8n-nodes-base.scheduleTrigger", "position":[250,300]
  },{
    "parameters":{"method":"GET","url":"http://localhost:8107/health","options":{}},
    "name": "HTTP Request", "type": "n8n-nodes-base.httpRequest", "position":[450,300]
  },{
    "parameters":{"combine":"any","conditions":{"string":[{"value1":"{{ $json.estado }}","operation":"equals","value2":"error"},{"value1":"{{ $json.estado }}","operation":"equals","value2":"warning"}]}},
    "name": "If error/warning", "type": "n8n-nodes-base.if", "position":[650,300]
  },{
    "parameters":{"fileName":"=/logs/n8n/alertas.jsonl","dataPropertyName":"data","data":"={{ JSON.stringify($json) }}"},
    "name": "Log Alert", "type": "n8n-nodes-base.writeFile", "position":[850,200]
  }],
  "connections":{
    "Schedule":{"main":[[{"node":"HTTP Request","type":"main","index":0}]]},
    "HTTP Request":{"main":[[{"node":"If error/warning","type":"main","index":0}]]},
    "If error/warning":{"main":[[{"node":"Log Alert","type":"main","index":0}],[]]},
    "Log Alert":{"main":[[]]}
  }
}
