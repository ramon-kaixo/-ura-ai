{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ura/schema/system_config",
  "title": "URA System Configuration Schema",
  "description": "Esquema declarativo para system_config.json. Validado por jsonschema.",
  "type": "object",
  "required": ["global_defaults", "profiles"],
  "properties": {
    "global_defaults": {
      "type": "object",
      "required": ["log_level", "retention_days", "patrones_clasificacion", "model_descriptions"],
      "properties": {
        "log_level": { "type": "string", "enum": ["DEBUG", "INFO", "WARNING", "ERROR"] },
        "retention_days": {
          "type": "object",
          "required": ["logs", "cache", "docker_build"],
          "properties": {
            "logs": { "type": "number" },
            "cache": { "type": "number" },
            "docker_build": { "type": "number" }
          }
        },
        "patrones_clasificacion": {
          "type": "object",
          "required": ["razonamiento", "codigo_complejo", "codigo_rapido", "respuesta_rapida"],
          "minProperties": 5
        },
        "model_descriptions": { "type": "object", "minProperties": 4 }
      }
    },
    "profiles": {
      "type": "object",
      "required": ["linux_asus", "darwin_mac"],
      "minProperties": 2,
      "properties": {
        "linux_asus": {
          "$ref": "#/$defs/profile"
        },
        "darwin_mac": {
          "$ref": "#/$defs/profile"
        },
        "linux_terminal": {
          "$ref": "#/$defs/profile"
        }
      }
    }
  },
  "$defs": {
    "profile": {
      "type": "object",
      "required": ["role", "hostname", "ollama", "router", "paths", "maintenance", "models", "fallback_model", "cache_ttl"],
      "properties": {
        "role": { "type": "string", "enum": ["client", "server"] },
        "hostname": { "type": "string" },
        "ollama": {
          "type": "object",
          "required": ["host", "port"],
          "properties": {
            "host": { "type": "string" },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
          }
        },
        "router": {
          "type": "object",
          "required": ["host", "port"],
          "properties": {
            "host": { "type": "string" },
            "port": { "type": "integer" }
          }
        },
        "paths": {
          "type": "object",
          "required": ["data", "logs", "maintenance_logs"]
        },
        "ssh": {
          "type": "object",
          "required": ["user", "timeout"],
          "properties": {
            "user": { "type": "string" },
            "timeout": { "type": "integer" }
          }
        },
        "swarm": {
          "type": "object",
          "required": ["devices_path"]
        },
        "maintenance": {
          "type": "object",
          "required": ["thresholds", "exclude_patterns", "allowed_temp_dirs", "allowed_log_dirs"],
          "properties": {
            "thresholds": {
              "type": "object",
              "required": ["docker_images", "docker_volumes", "cache_size", "log_size"]
            },
            "exclude_patterns": { "type": "array", "minItems": 10 },
            "allowed_temp_dirs": { "type": "array", "minItems": 1 },
            "allowed_log_dirs": { "type": "array", "minItems": 1 }
          }
        },
        "models": {
          "type": "object",
          "required": ["razonamiento", "codigo_complejo", "codigo_rapido", "respuesta_rapida"],
          "minProperties": 4
        },
        "fallback_model": { "type": "string" },
        "cache_ttl": { "type": "integer", "minimum": 60 },
        "rag": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "chunk_size": { "type": "integer" },
            "chunk_overlap": { "type": "integer" },
            "top_k": { "type": "integer" },
            "threshold": { "type": "number" }
          }
        }
      }
    }
  }
}
