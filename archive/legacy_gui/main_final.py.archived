    def __init__(self):
        super().__init__()
        self._init_config()
        self._init_connectors()
        self._init_memory()
        self._init_security()
        self._init_threads()
        self._init_ui()
        self._init_voice()

        # Inicializar thread pool global
        from core.thread_pool import get_thread_pool

        self.thread_pool = get_thread_pool(max_workers=10)

        # Inicializar caché inteligente
        from core.smart_cache import get_smart_cache

        self.smart_cache = get_smart_cache(default_ttl=300)

        # Inicializar health monitor
        from core.health_monitor import get_health_monitor

        self.health_monitor = get_health_monitor()
        self.health_monitor.start()

        # Inicializar central router
        from core.central_router import get_central_router

        self.central_router = get_central_router()

        self.start_autonomy_system()
        self.start_ollama_checker()
        if self.config.get("auto_start_windsurf", False):
            self.start_windsurf()
        if self.config.get("auto_start_panel", False):
            self.start_panel()
        self.start_monitoring()
        self.auto_start_services()

