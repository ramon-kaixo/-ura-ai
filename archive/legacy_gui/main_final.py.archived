#!/usr/bin/env python3
"""
URA App - Versión FINAL
Combinación de:
- Rediseño visual de URA_App_Redesign
- Voz arreglada de URA_App_Voice_Fixed
- Flujo unificado de URA_App_Unified_Flow
- Layout optimizado con proporciones perfectas
"""

from config.imports import *


