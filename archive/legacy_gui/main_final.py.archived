    def start_panel(self):
        """Iniciar panel web URA en un hilo separado"""
        import threading
        import subprocess
        import sys

        def run_panel():
            try:
                subprocess.run(
                    [sys.executable, str(Path(__file__).parent / "ura_panel.py")],
                    cwd=Path(__file__).parent,
                    check=True,
                )
            except subprocess.CalledProcessError as e:
                logger.error(f"Panel web terminó con error: {e}")
            except Exception as e:
                logger.error(f"Error iniciando panel web: {e}")

        panel_thread = threading.Thread(target=run_panel, daemon=True, name="URAPanelThread")
        panel_thread.start()
        logger.info("Panel web iniciado en hilo separado")

