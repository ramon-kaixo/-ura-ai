# URA — Configuración de Entorno
# Copia este archivo como .env y ajusta los valores

# General
URA_LOG_LEVEL=INFO
URA_HOST=0.0.0.0
URA_PORT=8000

# External Services
URA_OLLAMA_URL=http://ollama:11434
URA_QDRANT_URL=http://qdrant:6333

# Qdrant
QDRANT_PORT=6333

# Ollama (requires profile: docker compose --profile ollama up)
OLLAMA_PORT=11434

# Data directories
URA_DATA_DIR=./data
URA_CONFIG_DIR=./deploy

# GPU support (set to "false" for CPU-only)
URA_GPU_ENABLED=false
