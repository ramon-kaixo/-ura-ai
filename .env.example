# ============================================================
# URA — Environment Variables Reference
# Copy to .env or export in shell profile (~/.zshrc, ~/.bashrc)
# All vars have safe fallbacks — only override if different.
# ============================================================

# --- ASUS (neural core) ---
# IP/hostname of the ASUS GX10 machine (Ollama, Router, services)
ASUS_HOST="10.164.1.99"
# SSH target for ASUS (user@host)
ASUS_SSH="ramon@10.164.1.99"
# Remote path for URA repo on ASUS
ASUS_PATH="/home/ramon/URA/ura_ia_1972"
# Ollama endpoint on ASUS
OLLAMA_URL="http://10.164.1.99:11434"
# Model Router endpoint on ASUS
MODEL_ROUTER_URL="http://10.164.1.99:11435"

# --- Terminal (local machine — Mac, Germany, etc.) ---
# IP of the terminal that ASUS connects TO for heartbeats/sync
TERMINAL_HOST="10.164.1.26"
# SSH target from ASUS → terminal
TERMINAL_SSH="ramon@10.164.1.26"
# SSH user for the terminal (if different from ramon)
TERMINAL_USER="ramon"
# Local URA root on terminal
URA_ROOT="/Users/ramonesnaola/URA"

# --- Router ---
ROUTER_PASSWORD="your_linksys_recovery_key_here"
ROUTER_IP="192.168.1.1"

# --- Optional overrides ---
# Executor API on ASUS (port 4096)
ASUS_EXEC_URL="http://10.164.1.99:4096"
# MCP sync endpoint on terminal
MCP_SYNC_URL="http://10.164.1.26:9093"
# Backup target for backup_to_mac.sh
BACKUP_TARGET="/path/to/external/backup"
