{
  "version": "1.0",
  "description": "Libro de Operaciones de URA - Única Fuente de Verdad de Capacidades",
  "last_updated": "2026-04-22",
  "capabilities": {
    "FILESYSTEM_ACCESS": {
      "description": "Acceso al sistema de archivos local",
      "enabled": true,
      "scope": {
        "read_paths": [
          "~/",
          "~/Documents/",
          "~/Desktop/"
        ],
        "search_patterns": [
          "*.pdf",
          "*.xlsx",
          "*.csv",
          "*.txt",
          "*.md",
          "presupuesto*",
          "*cucaracha*"
        ],
        "allowed_operations": [
          "find",
          "ls",
          "cat",
          "grep",
          "head",
          "tail",
          "file",
          "stat"
        ]
      },
      "constraints": {
        "max_file_size_mb": 100,
        "forbidden_paths": [
          "/System/",
          "/Library/",
          "/private/"
        ]
      }
    },
    "EMAIL_INTEGRATION": {
      "description": "Acceso a datos de email mediante búsqueda de archivos",
      "enabled": true,
      "email_account": "kaixoura@gmail.com",
      "search_locations": [
        "~/Library/Mail/",
        "~/Documents/Email/",
        "~/Desktop/Email/"
      ],
      "allowed_operations": [
        "search",
        "read_attachments",
        "analyze_content"
      ],
      "constraints": {
        "require_authorization": true,
        "log_all_access": true
      }
    },
    "TERMINAL_EXECUTION": {
      "description": "Ejecución de comandos de sistema vía terminal_gateway",
      "enabled": true,
      "gateway_module": "terminal_gateway.py",
      "allowed_commands": {
        "read_only": [
          "find",
          "ls",
          "grep",
          "cat",
          "head",
          "tail",
          "ps",
          "df",
          "du",
          "pwd",
          "whoami",
          "file",
          "stat"
        ],
        "dangerous": [
          "rm",
          "sudo",
          "dd",
          "mkfs",
          "mv",
          "cp",
          "chmod",
          "chown"
        ]
      },
      "constraints": {
        "dangerous_commands_require_authorization": true,
        "timeout_seconds": 30,
        "require_privacy_scrubber": true
      }
    },
    "SECURITY_VALIDATION": {
      "description": "Filtrado de contenido sensible vía agente_policia_v2",
      "enabled": true,
      "guardian_module": "agente_policia_v2.py",
      "protection_layers": {
        "privacy_scrubber": {
          "module": "privacy_scrubber.py",
          "enabled": true,
          "scrub_targets": [
            "passwords",
            "tokens",
            "api_keys",
            "emails",
            "phone_numbers",
            "ssn",
            "credit_cards"
          ]
        },
        "consensus_validation": {
          "module": "consensus_system.py",
          "enabled": true,
          "min_consensus_threshold": 0.67
        }
      },
      "constraints": {
        "block_social_engineering": true,
        "block_injection_attempts": true,
        "require_explicit_approval_for_sensitive_operations": true
      }
    }
  },
  "operation_mappings": {
    "search_budget": {
      "capability": "FILESYSTEM_ACCESS",
      "required_tools": ["find", "grep"],
      "technical_steps": [
        "find ~/ -name '*presupuesto*' -type f",
        "grep -i 'cucaracha' ~/Documents/",
        "cat [archivo_encontrado]"
      ]
    },
    "search_pdf": {
      "capability": "FILESYSTEM_ACCESS",
      "required_tools": ["find", "file"],
      "technical_steps": [
        "find ~/ -name '*.pdf' -type f",
        "file [archivo_pdf] para validar tipo",
        "cat [archivo_pdf]"
      ]
    },
    "analyze_email": {
      "capability": "EMAIL_INTEGRATION",
      "required_tools": ["find", "grep"],
      "technical_steps": [
        "find ~/Library/Mail/ -name '*.emlx'",
        "grep -i 'presupuesto' [archivos_email]",
        "extract_attachments si existen"
      ]
    },
    "execute_command": {
      "capability": "TERMINAL_EXECUTION",
      "required_tools": ["terminal_gateway"],
      "technical_steps": [
        "validar comando contra lista de permitidos",
        "si es peligroso, solicitar autorización",
        "ejecutar vía terminal_gateway.execute_command()",
        "aplicar privacy_scrubber a salida"
      ]
    }
  }
}
