[Unit]
Description=URA Model Router Alert Monitor
Documentation=https://github.com/anomalyco/ura

[Service]
Type=oneshot
User=root
ExecStart=/bin/bash -c 'journalctl -u model-router.service --since "1 hour ago" 2>/dev/null | grep -c "Failed with result" | awk "{if(\$1>5) exit 1; else exit 0}"'
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
