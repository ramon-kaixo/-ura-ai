// Polkit rule: allow user ramon to manage URA systemd services
// Place in /etc/polkit-1/rules.d/10-ura.rules
polkit.addRule(function (action, subject) {
    if (subject.user == "ramon" &&
        action.id.startsWith("org.freedesktop.systemd1.manage-units") &&
        action.lookup("unit").startsWith("ura-")) {
        return polkit.Result.YES;
    }
});

// Allow restarting any systemd unit without password
polkit.addRule(function (action, subject) {
    if (subject.user == "ramon" &&
        (action.id == "org.freedesktop.systemd1.manage-unit-files" ||
         action.id == "org.freedesktop.systemd1.reload-daemon")) {
        return polkit.Result.YES;
    }
});
