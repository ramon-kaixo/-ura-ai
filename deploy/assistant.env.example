# URA Assistant — Configuración de entorno
# Copia este archivo a /etc/ura/assistant.env y ajusta los valores

# API Key para autenticación (vacío = sin autenticación)
URA_API_KEY=

# Directorio de datos persistentes
URA_DATA_DIR=/home/ramon/.ura

# Timeout para llamadas LLM (segundos)
URA_LLM_TIMEOUT=30

# Modelo rápido (por defecto)
URA_LLM_MODEL_FAST=qwen2.5:7b
