[Unit]
Description=URA Assistant Conversacional — FastAPI
After=network.target ollama.service
Wants=ollama.service

[Service]
Type=simple
User=ramon
WorkingDirectory=/home/ramon/URA/ura_ia_1972
Environment=URA_HOST=0.0.0.0
Environment=URA_PORT=8003
Environment=URA_DATA_DIR=/home/ramon/.ura
Environment=URA_LLM_TIMEOUT=30
Environment=PYTHONPATH=/home/ramon/URA/ura_ia_1972
EnvironmentFile=/etc/ura/assistant.env
ExecStart=/usr/bin/python3 -m uvicorn motor.assistant.main:app --host 0.0.0.0 --port 8003
Restart=on-failure
RestartSec=5
TimeoutStartSec=30

[Install]
WantedBy=multi-user.target
